[delayed_gcode DELAYED_PRINTER_OFF]
initial_duration = 0.
gcode =
  {% if printer.idle_timeout.state == "Idle" %}
    {% if printer["extruder"].temperature > 50 %}
      UPDATE_DELAYED_GCODE ID=DELAYED_PRINTER_OFF DURATION=60
    {% else %}
#      WLED_OFF STRIP=roof
      POWER_OFF_PRINTER
    {% endif %}
  {% else %}
    M118 Printer not idle, cancelled PRINTER_OFF.
  {% endif %}

[sdcard_loop]

[gcode_macro START_LOOP]
description: Compatibilidad con perfiles antiguos de Orca
gcode:
  { action_respond_info("START_LOOP en modo compatibilidad (sin loop de Klipper)") }

[gcode_macro STOP_LOOPING]
description: Compatibilidad con perfiles antiguos de Orca
gcode:
  { action_respond_info("STOP_LOOPING en modo compatibilidad (sin loop de Klipper)") }

[gcode_macro PRINT_FINISHED]
description: Cierre ligero; la transicion la maneja Moonraker Job Queue
gcode:
  { action_respond_info("Print finished") }

[gcode_macro QUEUE_TRANSITION]
description: Transicion entre trabajos del Job Queue (Moonraker): enfria a 45 C y luego empuja la pieza
gcode:
  { action_respond_info("Queue: iniciando transicion...") }

  G91
  G1 Z5 F1800
  G90

  SET_GCODE_VARIABLE MACRO=COOLDOWN VARIABLE=extruder_temp VALUE=175
  SET_GCODE_VARIABLE MACRO=COOLDOWN VARIABLE=bed_temp VALUE=45
  COOLDOWN

  MANUAL_CLEAR_BED

  { action_respond_info("Queue: transicion lista. Cargando siguiente trabajo...") }

[gcode_macro END_PRINT]
gcode:
  { action_respond_info("terminando...") }

  # Restablecer estado runtime de material al finalizar.
  SET_GCODE_VARIABLE MACRO=MATERIAL_RUNTIME VARIABLE=abs_fan_lock VALUE=0

  # Retraccion corta para reducir hilo al terminar.
  G91
  G1 E-2 F2700
  G1 E-2 Z0.2 F2400
  G90

  # Presentacion de pieza: subir Z y llevar cama/cabezal a posicion visible.
  {% if "xyz" in printer.toolhead.homed_axes %}
    {% set x_park = (printer.toolhead.axis_maximum.x|float) / 2.0 %}
    {% set y_park = (printer.toolhead.axis_maximum.y|float) - 5.0 %}
    {% set z_now = printer.toolhead.position.z|float %}
    {% set z_max = printer.toolhead.axis_maximum.z|float %}
    {% set z_park = z_now + 10.0 %}
    {% if z_park > z_max %}
      {% set z_park = z_max %}
    {% endif %}

    G1 Z{z_park} F1200
    G1 X{x_park} Y{y_park} F6000
  {% endif %}

  # Apagado de calentadores y ventilador de capa.

  M106 S0
  M104 S0
  M140 S0
  TURN_OFF_HEATERS

[gcode_macro PRINT_END]
description: End of printing
gcode:
  END_PRINT
